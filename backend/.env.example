# ═══════════════════════════════════════════════════════
# 基于 YOLOv11 的⽬标检测智能体平台 — 环境变量配置
# ═══════════════════════════════════════════════════════
# ── OpenAI API 配置（根据项⽬需求进⾏修改使⽤） ─────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# ── Qwen API 配置 ───────────────────────────────────
QWEN_API_KEY=sk-your-qwen-api-key
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/textgeneration/generation
# Qwen 兼容模式 API（⽤于 LangChain OpenAI 客户端）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ── 数据库配置 ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your-database-name
DB_USER=your-database-username
DB_PASSWORD=your-database-password
# ── Redis 配置 ──────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# 开发环境：本地 Docker
DATABASE_URL=postgresql://your-database-username:your-databasepassword@localhost:5432/your-database-name
# ⽣产环境：取消下⼀⾏的注释并注释掉上⾯的⾏
# DATABASE_URL=postgresql://your-database-username:your-secure-password@yourhost:5432/your-database-name
# ── 本地 LLM 配置（可选）────────────────────
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# ── Redis 配置 ───────────────────────────────────────
# 开发环境：本地 Docker
REDIS_URL=redis://localhost:6379/0
# ⽣产环境：取消下⼀⾏的注释并注释掉上⾯的⾏
# REDIS_URL=redis://:your-redis-password@your-redis-host:6379/0
# ── MinIO 对象存储配置 ───────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=L-images
MINIO_SECURE=false
# ── JWT 认证配置 ─────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# ── 百度OCR API 配置 ──────────────────────────────
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key
# ── 应⽤配置 ─────────────────────────────────────────
APP_NAME=L Agent Platform
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO
# ── SignAnalayzer 智能体配置 ────────────────────────
# ── Windows 本地模式与交通标志双模型 ───────────────
APP_MODE=local
DATABASE_URL=sqlite:///./data/local.db
REDIS_ENABLED=false
MINIO_ENABLED=false
YOLO_MODEL_PATH=../training/runs/tt100k_yolo11n_gpu/weights/best.pt
YOLO_MODEL_NAME=tt100k-yolo11n
YOLO_MODEL_TYPE=yolov11n
YOLO_DEVICE=auto
YOLO_CANONICALIZE_TT100K_CLASSES=true
YOLO_USE_SAHI=false
YOLO_SAHI_SLICE_HEIGHT=512
YOLO_SAHI_SLICE_WIDTH=512
YOLO_SAHI_OVERLAP_RATIO=0.2
YOLO_SAHI_MODEL_IMAGE_SIZE=640
YOLO_SAHI_STANDARD_PREDICTION=true
YOLO_CONFIDENCE=0.25
YOLO_IOU=0.45
YOLO_IMAGE_SIZE=1280
GTSRB_MODEL_PATH=../training/runs/gtsrb_yolo11n_cls_gpu_final/weights/best.pt
GTSRB_DEVICE=auto
GTSRB_IMAGE_SIZE=128
GTSRB_CROP_MAX_DIMENSION=512
# ── CORS 配置 ────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
