# TrafficAgent local configuration template.
# Model paths are resolved from the backend working directory.
YOLO_MODEL_PATH=../models/tt100k-yolo11s-reference42.pt
YOLO_MODEL_NAME=tt100k-yolo11s-reference42
YOLO_MODEL_TYPE=yolov11s
YOLO_DEVICE=auto
YOLO_CANONICALIZE_TT100K_CLASSES=true
YOLO_USE_SAHI=true
YOLO_SAHI_SLICE_HEIGHT=512
YOLO_SAHI_SLICE_WIDTH=512
YOLO_SAHI_OVERLAP_RATIO=0.2
YOLO_SAHI_MODEL_IMAGE_SIZE=640
YOLO_SAHI_STANDARD_PREDICTION=true
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.45
YOLO_IMAGE_SIZE=640
YOLO_MAX_BATCH_IMAGES=20
YOLO_MAX_IMAGE_BYTES=10485760

GTSRB_MODEL_PATH=../models/gtsrb-yolo11n-cls.pt
GTSRB_DEVICE=auto
GTSRB_IMAGE_SIZE=128
GTSRB_CROP_MAX_DIMENSION=512

VIDEO_MAX_BYTES=52428800
VIDEO_FRAME_SAMPLE_RATE=1
VIDEO_MAX_FRAMES=0
VIDEO_PREVIEW_INTERVAL_FRAMES=10
VIDEO_KEY_FRAME_INTERVAL_SECONDS=1.0
VIDEO_MAX_KEY_FRAMES=100
VIDEO_BOX_PERSISTENCE_FRAMES=3
VIDEO_ANNOTATION_FONT_PATH=
VIDEO_WORKERS=2
VIDEO_MAX_PENDING_TASKS=4
VIDEO_PROGRESS_TTL_SECONDS=3600
VIDEO_TEMP_DIR=./uploads/videos
VIDEO_STATUS_DIR=./data/video_status
CAMERA_CPU_IMAGE_SIZE=416
CAMERA_GPU_IMAGE_SIZE=640
CAMERA_MAX_FRAME_BYTES=2097152
DETECTION_OUTPUT_DIR=./uploads/detections

APP_MODE=local
DATABASE_URL=sqlite:///./data/local.db
REDIS_ENABLED=false
MINIO_ENABLED=false

APP_NAME=TrafficAgent
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# bootstrap-windows.ps1 generates backend/.env separately with a random secret.
# This marker documents that requirement; the template is not directly runnable.
JWT_SECRET_KEY=generated-by-bootstrap
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional external services. Leave empty when unused.
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
